# Copy this file to ".env" and fill in your secrets.
# .env is gitignored — never commit your real keys.

# Google Gemini (free tier, 1500 req/day) — required for the GEMINI Copilot mode.
# Get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama runtime URL — only needed if you run a non-default port.
# OLLAMA_BASE_URL=http://localhost:11434
